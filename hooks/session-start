#!/usr/bin/env bash
# UNITARES Governance Plugin — SessionStart hook
#
# Identity-honesty Part C (Session C, 2026-04-17):
# This hook no longer creates an identity on the agent's behalf. It confirms
# governance is reachable, loads the fundamentals skill, and emits context
# instructing the agent to make its own first MCP tool call (onboard /
# identity / bind_session). The post-identity PostToolUse hook captures the
# response and writes the session cache.
#
# See docs/specs/2026-04-17-session-start-stops-creating-identities.md
# in the unitares repo for the architectural rationale.
set -euo pipefail

# ---------------------------------------------------------------------------
# Resolve plugin root and helpers
# ---------------------------------------------------------------------------
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

DEFAULTS_FILE=""
for candidate in \
  "${PLUGIN_ROOT}/config/defaults.env" \
  "${PLUGIN_ROOT}/config/client/defaults.env"
do
  if [[ -f "${candidate}" ]]; then
    DEFAULTS_FILE="${candidate}"
    break
  fi
done

FRESHNESS_WARNING_HELPER=""
for candidate in \
  "${PLUGIN_ROOT}/scripts/_freshness_warning.py" \
  "${PLUGIN_ROOT}/scripts/client/_freshness_warning.py"
do
  if [[ -f "${candidate}" ]]; then
    FRESHNESS_WARNING_HELPER="${candidate}"
    break
  fi
done

# Preserve operator-provided env overrides across defaults.env sourcing.
SERVER_URL_OVERRIDE="${UNITARES_SERVER_URL-}"
if [[ -n "${DEFAULTS_FILE}" ]]; then
  # shellcheck source=/dev/null
  source "${DEFAULTS_FILE}"
fi
if [[ -n "${SERVER_URL_OVERRIDE}" ]]; then
  UNITARES_SERVER_URL="${SERVER_URL_OVERRIDE}"
fi

SERVER_URL="${UNITARES_SERVER_URL:-http://localhost:8767}"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
escape_for_json() {
  python3 -c "
import json, sys
print(json.dumps(sys.argv[1])[1:-1])
" "$1"
}

# ---------------------------------------------------------------------------
# Load a short reference snippet via S15-c fetch helper.
#
# The helper tries server fetch (cache → /v1/tools/call skills tool) and
# falls back to the bundled mirror at
# ${PLUGIN_ROOT}/skills/governance-fundamentals/SKILL.md when MCP is
# unreachable. Stderr [FETCH_SKILLS_*] breadcrumbs distinguish fresh
# vs. cached vs. bundled-fallback so the degraded state is legible
# (axiom #14). On total failure (helper missing + no bundled mirror)
# SessionStart still ships — just without the Fundamentals excerpt
# block, same as pre-S15-c when the file was simply missing.
# ---------------------------------------------------------------------------
SKILL_CONTENT=""
SKILL_SOURCE=""
FETCH_SKILLS_HELPER="${PLUGIN_ROOT}/scripts/_fetch_skills.py"
SKILL_FETCHED=""
SKILL_STDERR_FILE=""
if [[ -f "${FETCH_SKILLS_HELPER}" ]]; then
  SKILL_STDERR_FILE=$(mktemp -t unitares-fetch-skills.XXXXXX 2>/dev/null || true)
  if [[ -n "${SKILL_STDERR_FILE}" ]]; then
    SKILL_FETCHED=$(python3 "${FETCH_SKILLS_HELPER}" \
      --name governance-fundamentals \
      --plugin-root "${PLUGIN_ROOT}" \
      --server-url "${SERVER_URL}" \
      --print-source 2>"${SKILL_STDERR_FILE}" || true)
    # Pull the `source=<label>` line so the agent-facing excerpt header
    # can carry an honesty marker on the offline path. Operators see the
    # full breadcrumb stream in HEALTH_LOG when they need it.
    SKILL_SOURCE=$(grep -E '^source=' "${SKILL_STDERR_FILE}" 2>/dev/null | tail -1 | sed -e 's/^source=//' || true)
    if [[ -n "${HEALTH_LOG:-}" ]]; then
      cat "${SKILL_STDERR_FILE}" >>"${HEALTH_LOG}" 2>/dev/null || true
    fi
    rm -f "${SKILL_STDERR_FILE}"
  else
    SKILL_FETCHED=$(python3 "${FETCH_SKILLS_HELPER}" \
      --name governance-fundamentals \
      --plugin-root "${PLUGIN_ROOT}" \
      --server-url "${SERVER_URL}" 2>/dev/null || true)
  fi
fi
if [[ -n "${SKILL_FETCHED}" ]]; then
  SKILL_CONTENT="$(printf '%s\n' "${SKILL_FETCHED}" | sed -n '1,80p')"
else
  # Helper missing or returned empty — last-ditch direct read of the
  # bundled mirror so SessionStart never ships an empty excerpt when a
  # local SKILL.md is on disk.
  SKILL_FILE="${PLUGIN_ROOT}/skills/governance-fundamentals/SKILL.md"
  if [[ -f "${SKILL_FILE}" ]]; then
    SKILL_CONTENT="$(sed -n '1,80p' "${SKILL_FILE}")"
    SKILL_SOURCE="${SKILL_SOURCE:-bundled_direct}"
  fi
fi

# Agent-facing honesty marker: when content came from an offline path,
# the excerpt header carries a "(...)" suffix so the agent can tell it
# is reading potentially-stale-vs-current-tool-descriptions content.
# The §6 authority hierarchy says skills must not contradict tool
# descriptions; in offline-fallback the contradiction risk is real and
# bounded by plugin install age. Surfacing the marker is the honesty
# acknowledgment in the agent's view, not just operator stderr.
SKILL_SOURCE_SUFFIX=""
case "${SKILL_SOURCE}" in
  offline_bundled|bundled_direct)
    SKILL_SOURCE_SUFFIX=" (bundled mirror — server unreachable, may be stale)" ;;
  offline_cache)
    SKILL_SOURCE_SUFFIX=" (cached — server unreachable)" ;;
  fresh_stale)
    SKILL_SOURCE_SUFFIX=" (server flagged stale)" ;;
esac

if [[ -n "${SKILL_CONTENT}" && -n "${FRESHNESS_WARNING_HELPER}" ]]; then
  FRESHNESS_WARNING=$(python3 "${FRESHNESS_WARNING_HELPER}" "${SKILL_CONTENT}" 2>/dev/null || true)
  if [[ -n "${FRESHNESS_WARNING}" ]]; then
    SKILL_CONTENT="${FRESHNESS_WARNING}

${SKILL_CONTENT}"
  fi
fi

# ---------------------------------------------------------------------------
# Workspace-local lineage probe — slot-scoped only.
#
# IMPORTANT: we deliberately do NOT enumerate ~/.unitares/session-*.json.
# That glob produced an unfiltered cross-instance UUID menu, which — paired
# with an `identity(agent_uuid=..., resume=true)` suggestion — invited
# fresh agents to pattern-match on model name and resume into other
# instances' identities. See KG bug 2026-04-20T00:09:51.
#
# We also deliberately do NOT read the bare ./.unitares/session.json.
# The "owned by the process-instance that previously ran in THIS directory"
# assumption breaks when the workspace is shared across concurrent claude
# processes — notably the discord-dispatch case, where threads defaulting
# to cwd=HOME all shared /Users/cirwel/.unitares/session.json and silently
# funneled onto whichever agent last wrote the cache. That's the flaw
# this hook is tightening against; the dispatch-side fix (per-thread
# scratch dirs) is complementary, not redundant.
#
# The slot-scoped cache ./.unitares/session-<claude_session_id>.json, by
# contrast, is owned by one specific claude process session. On --resume
# it matches; a fresh session writes its own. Under the identity ontology
# its UUID is surfaced as a *lineage
# candidate* — the predecessor this fresh process declares via
# `parent_agent_id` — NOT as a resume credential.
# ---------------------------------------------------------------------------
WORKSPACE_LINEAGE_HINT=""
CLAUDE_SESSION_ID=""
# Claude Code sends the hook event as JSON on stdin, including session_id.
if [[ ! -t 0 ]]; then
  SESSION_START_STDIN=$(cat 2>/dev/null) || SESSION_START_STDIN=""
  if [[ -n "${SESSION_START_STDIN}" ]]; then
    CLAUDE_SESSION_ID=$(python3 - "${SESSION_START_STDIN}" <<'PY' 2>/dev/null || true
import json, sys
try:
    data = json.loads(sys.argv[1])
    print((data.get("session_id") or "").strip())
except Exception:
    pass
PY
    )
  fi
fi

WORKSPACE_CACHE=""
NUDGE_MARKER=""
NUDGE_ALREADY_SHOWN=0
if [[ -n "${CLAUDE_SESSION_ID}" ]]; then
  # Match session_cache.py _slot_suffix: alnum + [-_], cap at 64 chars.
  SAFE_SLOT=$(python3 - "${CLAUDE_SESSION_ID}" <<'PY' 2>/dev/null || true
import sys
raw = sys.argv[1]
safe = "".join(c if c.isalnum() or c in ("-", "_") else "_" for c in raw)
print(safe[:64])
PY
  )
  if [[ -n "${SAFE_SLOT}" ]]; then
    WORKSPACE_CACHE="${PWD}/.unitares/session-${SAFE_SLOT}.json"
    NUDGE_MARKER="${PWD}/.unitares/session-start-nudge-${SAFE_SLOT}.json"
  fi
fi

# ---------------------------------------------------------------------------
# Compact mode — when this workspace already has a fresh slot-scoped cache
# (mtime < 1h), the agent has almost certainly seen the full Fundamentals
# excerpt and the long onboard-prose this hour. Per-turn SessionStart
# resume events fire frequently in normal Claude Code use; re-injecting
# the full ~3KB context every fire is repetition without information.
# We collapse to a one-line prompt and skip the Fundamentals block.
#
# The trigger is intentionally workspace-scoped — fresh workspaces
# (no cache yet) get the full onboarding prose, which is the right
# default for an agent that hasn't seen it.
# ---------------------------------------------------------------------------
COMPACT_MODE=0
COMPACT_TTL_SECS="${UNITARES_HOOK_COMPACT_TTL:-3600}"
if [[ -n "${WORKSPACE_CACHE}" && -f "${WORKSPACE_CACHE}" ]]; then
  CACHE_MTIME=$(python3 - "${WORKSPACE_CACHE}" <<'PY' 2>/dev/null || echo 0
import os
import sys

try:
    print(int(os.path.getmtime(sys.argv[1])))
except Exception:
    print(0)
PY
)
  CACHE_AGE_SECS=$(( $(date +%s) - CACHE_MTIME ))
  if (( CACHE_MTIME > 0 && CACHE_AGE_SECS >= 0 && CACHE_AGE_SECS < COMPACT_TTL_SECS )); then
    COMPACT_MODE=1
  fi
fi
if [[ -n "${NUDGE_MARKER}" && ! -f "${WORKSPACE_CACHE}" && -f "${NUDGE_MARKER}" ]]; then
  NUDGE_ALREADY_SHOWN=1
fi

# ---------------------------------------------------------------------------
# Orchestrator-provisioned lineage (spawn-context env) — highest confidence.
#
# The BEAM agent orchestrator (unitares PR #648) provisions
# UNITARES_PARENT_AGENT_ID / UNITARES_SPAWN_REASON into the env of agents it
# spawns. Unlike the slot-file and scan-newest sources below, this is ground
# truth from the process that created THIS process-instance — not an
# inference from workspace files — so it outranks both. Same posture as
# those sources: a lineage CANDIDATE declared via parent_agent_id, never a
# resume credential; the agent decides whether to declare it.
#
# Both values are shape-checked before they can appear inside the suggested
# tool-call template: a polluted env var must not become a copy-pasteable
# false-ancestry suggestion (UUID) or break out of the quoted template
# (spawn reason).
# ---------------------------------------------------------------------------
ENV_PARENT_UUID="${UNITARES_PARENT_AGENT_ID:-}"
if [[ -n "${ENV_PARENT_UUID}" ]]; then
  if [[ "${ENV_PARENT_UUID}" =~ ^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$ ]]; then
    ENV_SPAWN_REASON="${UNITARES_SPAWN_REASON:-subagent}"
    if [[ ! "${ENV_SPAWN_REASON}" =~ ^[A-Za-z0-9_-]{1,64}$ ]]; then
      ENV_SPAWN_REASON="subagent"
    fi
    WORKSPACE_LINEAGE_HINT="Orchestrator-provisioned lineage candidate (spawn-context env). The process that spawned this instance set \`UNITARES_PARENT_AGENT_ID\` — ground truth from the spawner, not an inference from workspace files. Spawn reason: ${ENV_SPAWN_REASON}.

Under the identity ontology, a fresh process-instance declares lineage rather than resuming identity. To record the inheritance chain, include in the start_session/onboard call below:
    start_session(force_new=true, parent_agent_id=\"${ENV_PARENT_UUID}\", spawn_reason=\"${ENV_SPAWN_REASON}\")
This is a candidate, not an obligation — if it does not match how this process came to exist, omit \`parent_agent_id\` and onboard fresh. Memory, KG notes, and self-knowledge persist across instances; governance-identity does not."
  fi
fi

if [[ -z "${WORKSPACE_LINEAGE_HINT}" && -n "${WORKSPACE_CACHE}" && -f "${WORKSPACE_CACHE}" ]]; then
  WORKSPACE_LINEAGE_HINT=$(python3 - "${WORKSPACE_CACHE}" <<'PY' 2>/dev/null || true
import json, sys
from pathlib import Path

cache = Path(sys.argv[1])
try:
    data = json.loads(cache.read_text(encoding="utf-8"))
except Exception:
    sys.exit(0)

uuid = (data.get("uuid") or data.get("agent_uuid") or "").strip()
if not uuid:
    sys.exit(0)

label = data.get("display_name") or data.get("agent_id") or ""
ts = data.get("updated_at", "")
date_part = ts[:10] if ts else ""

header = "A prior process-instance ran in this workspace"
if label:
    header += f" as {label}"
if date_part:
    header += f" (last active {date_part})"
header += f"; UUID `{uuid}`."

print(
    header + "\n\nUnder the identity ontology a fresh process-instance "
    "onboards fresh — co-location in this workspace is not lineage. "
    "Onboard fresh:\n"
    "    start_session(force_new=true)\n"
    "Declare this UUID as a parent ONLY if that prior session has EXITED "
    "and you are a deliberate continuation of it:\n"
    f"    start_session(force_new=true, parent_agent_id=\"{uuid}\", spawn_reason=\"explicit\")\n"
    "If that session is still running it is a concurrent sibling, not a "
    "predecessor, and the server rejects the claim "
    "(lineage_coincidental_rejected). Memory, KG notes, and self-knowledge "
    "persist across instances; governance-identity does not."
)
PY
)
fi

# ---------------------------------------------------------------------------
# Scan-newest secondary lineage fallback (S20.2 / §3b)
#
# When a Claude session_id is present but its slot-scoped cache file does
# not exist (cross-`/clear` case: harness minted a fresh session_id, prior
# work in this workspace lives under a different slot), fall back to
# `session_cache.py list --workspace "$PWD"` and surface the **newest** prior slot's
# UUID as a lineage candidate. This is the cross-`/clear` lineage
# discovery the slot-scoped reader can't do alone.
#
# Strict constraints to honor existing axiom commitments:
#   - SHOW ONE, NEVER A MENU. The KG bug 2026-04-20T00:09:51 forbids
#     emitting a UUID list — that pattern invited fresh agents to
#     pattern-match and resume into other instances' identities. Newest-
#     only single hint preserves the lineage signal without the menu.
#   - TTL filter (default 30d, `UNITARES_HOOK_LINEAGE_MAX_AGE_DAYS`).
#     Stale slots from long-dead sessions otherwise sort to the top of
#     `cmd_list` and mis-rank the newest-pick.
#   - LINEAGE CANDIDATE, NEVER RESUME CREDENTIAL. Same framing as the
#     slot-match path — declared via parent_agent_id, not bearer-resumed.
#   - Honesty marker: the surfaced text says "scan-newest" so the agent
#     can distinguish a slot match (high confidence — same Claude
#     conversation) from a workspace match (this workspace's most recent
#     prior session, but possibly a different harness invocation).
# ---------------------------------------------------------------------------
if [[ -n "${CLAUDE_SESSION_ID}" && -z "${WORKSPACE_LINEAGE_HINT}" ]]; then
  SESSION_CACHE_HELPER=""
  for candidate in \
    "${PLUGIN_ROOT}/scripts/session_cache.py" \
    "${PLUGIN_ROOT}/scripts/client/session_cache.py"
  do
    if [[ -f "${candidate}" ]]; then
      SESSION_CACHE_HELPER="${candidate}"
      break
    fi
  done

  if [[ -n "${SESSION_CACHE_HELPER}" ]]; then
    LINEAGE_MAX_AGE_DAYS="${UNITARES_HOOK_LINEAGE_MAX_AGE_DAYS:-30}"
    SCAN_LIST_JSON=$(python3 "${SESSION_CACHE_HELPER}" list --workspace "${PWD}" 2>/dev/null || true)
    if [[ -n "${SCAN_LIST_JSON}" ]]; then
      # Pass JSON via env var, not pipe-into-`python3 -`. Bash's
      # `cmd | python3 - <<'PY' ... PY` is broken: the heredoc and the
      # pipe both target fd 0, the heredoc wins for the script body,
      # and the pipe contents leak into the script source — silently
      # failing under `|| true` so the feature never surfaces. Env var
      # also avoids the ARG_MAX risk that ruled out argv passing.
      WORKSPACE_LINEAGE_HINT=$(SCAN_LIST_JSON="${SCAN_LIST_JSON}" \
        python3 - "${LINEAGE_MAX_AGE_DAYS}" <<'PY' 2>/dev/null || true
import json, os, sys
from datetime import datetime, timezone, timedelta

try:
    entries = json.loads(os.environ.get("SCAN_LIST_JSON", ""))
    max_age_days = int(sys.argv[1])
except Exception:
    sys.exit(0)
if not isinstance(entries, list):
    sys.exit(0)

now = datetime.now(timezone.utc)
cutoff = now - timedelta(days=max(0, max_age_days))
# Reject timestamps further in the future than small clock-skew
# tolerance — a same-UID actor can write `session-attacker.json` with
# updated_at="2099-..." and a chosen UUID, and a future-only TTL gate
# would surface the attacker UUID as the lineage candidate. Cap the
# accepted ceiling to "now plus a few minutes" so legitimate clock
# drift still passes but planted-future entries are rejected.
ceiling = now + timedelta(minutes=5)

def parse_ts(value):
    if not isinstance(value, str) or not value:
        return None
    try:
        return datetime.fromisoformat(value.replace("Z", "+00:00"))
    except Exception:
        return None

# cmd_list sorts by parsed UTC datetime (S20.2 fix). Pick the first
# entry that has an identity field AND is within [cutoff, ceiling].
# Slot-less legacy rows (slot is null) are excluded — they can't be
# the cross-`/clear` lineage we are looking for; only true
# slot-scoped predecessors are. Do NOT early-break on a single
# out-of-window entry — a malformed updated_at sorts to the bottom
# but a future-dated planted entry can sort to the top, and we must
# still find the next valid entry behind it.
chosen = None
for entry in entries:
    if not isinstance(entry, dict):
        continue
    if entry.get("slot") is None:
        continue
    uuid = (entry.get("parent_agent_id") or "").strip()
    if not uuid:
        continue
    ts = parse_ts(entry.get("updated_at"))
    if ts is None:
        continue
    if ts < cutoff or ts > ceiling:
        continue
    chosen = (uuid, entry, ts)
    break

if chosen is None:
    sys.exit(0)

uuid, entry, ts = chosen
date_part = ts.date().isoformat()
slot = entry.get("slot") or ""
age_secs = max(0, int((now - ts).total_seconds()))
if age_secs < 3600:
    age_text = f"{max(1, age_secs // 60)}m ago"
elif age_secs < 86400:
    age_text = f"{age_secs // 3600}h ago"
else:
    age_text = f"{age_secs // 86400}d ago"

# Honesty marker comes FIRST so a pattern-matching agent that copies
# only the surrounding context for the UUID still reads the
# disclaimer. The framing is "another process-instance" rather than
# "another Claude session" because the workspace can be shared with
# Codex, dispatch workers, or ad-hoc scripts that write slot files
# but aren't this Claude harness. The UUID appears only inside the
# parent_agent_id template — never as a standalone backticked token —
# so an agent that copies the literal string also copies its
# lineage-only intent.
print(
    "Scan-newest workspace slot (NOT a slot match for the current "
    "session, and NOT lineage by default). Another process-instance "
    f"previously wrote a slot file in this workspace — slot `{slot}`, last "
    f"active {date_part} ({age_text}). The prior process may have been a "
    "different Claude session (e.g. before `/clear`), a Codex run, a "
    "dispatch worker, or an ad-hoc script.\n\nUnder the identity ontology "
    "onboard fresh — co-location is not lineage:\n"
    "    start_session(force_new=true)\n"
    "Declare this UUID as a parent ONLY if that prior process has EXITED "
    "and you are a deliberate continuation of its work:\n"
    f"    start_session(force_new=true, parent_agent_id=\"{uuid}\", spawn_reason=\"explicit\")\n"
    "If it is still running it is a concurrent sibling, not a predecessor — "
    "the server rejects such claims (lineage_coincidental_rejected) and "
    "false ancestry pollutes the lineage DAG. Memory, KG notes, and "
    "self-knowledge persist across instances; governance-identity does not."
)
PY
)
    fi
  fi
fi

# ---------------------------------------------------------------------------
# Ping governance server
# ---------------------------------------------------------------------------
HEALTH_LOG="${UNITARES_SESSION_START_LOG:-/tmp/unitares-session-start.log}"
HEALTH_EXIT=0
HEALTH_STATUS=$(curl -sS --max-time 3 "${SERVER_URL}/health" 2>>"${HEALTH_LOG}") || HEALTH_EXIT=$?
printf '[%s] curl exit=%d len=%d url=%s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "${HEALTH_EXIT}" "${#HEALTH_STATUS}" "${SERVER_URL}/health" >> "${HEALTH_LOG}" 2>/dev/null || true

if [[ -z "${HEALTH_STATUS}" ]]; then
  CONTEXT="UNITARES Governance: OFFLINE (${SERVER_URL} unreachable). No governance identity is currently bound for this session. Governance tools may be unavailable."
  if [[ -n "${SKILL_CONTENT}" ]]; then
    CONTEXT="${CONTEXT}

--- Governance Fundamentals (reference) ---
${SKILL_CONTENT}"
  fi
else
  if [[ "${COMPACT_MODE}" == "1" ]]; then
    # Compact prose: assumes the agent saw the full note + Fundamentals
    # excerpt earlier this hour (workspace cache mtime < TTL). Keep
    # `force_new=true` (force_new pin-resume guard, regression-tested),
    # the ontology pointer (so a forgetful agent can re-read), and the
    # operator escape hatch — drop everything else.
    CONTEXT="UNITARES Governance: ONLINE
Slot-scoped governance state is present for this session. Continue normally.
Use \`sync_state(...)\` only for meaningful state worth reporting; do not create a check-in just to satisfy a hook reminder.
If you intentionally need a fresh governance identity for this process, use \`start_session(force_new=true)\` (\`onboard(...)\` canonical) and declare \`parent_agent_id\` only for a real spawn/handoff (see lineage hint below), not for co-location.
After governance calls, read \`next_action\`, \`memory_suggestions\`, and \`recovery_hint\` when present.
Recovery: run /diagnose."
  elif [[ "${NUDGE_ALREADY_SHOWN}" == "1" ]]; then
    CONTEXT="UNITARES Governance: ONLINE
Onboarding context was already shown for this session. If no identity is cached by turn stop, the Stop hook will lazily create a slot-scoped governance identity before emitting its substrate summary.
Use \`sync_state(...)\` only for meaningful state worth reporting. Do not manufacture a check-in for this reminder.
Recovery: run /diagnose."
  else
    if [[ -n "${NUDGE_MARKER}" ]]; then
      mkdir -p "$(dirname "${NUDGE_MARKER}")" 2>/dev/null || true
      printf '{"shown_at":"%s"}\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" >"${NUDGE_MARKER}" 2>/dev/null || true
    fi
    CONTEXT="UNITARES Governance: ONLINE

Identity attribution: bind this process to governance before substantive
work when you can. Call:

    start_session(force_new=true)          # canonical/raw: onboard(force_new=true)

SessionStart has not created an identity yet. If you do not bind manually,
the Stop hook will lazily create a slot-scoped identity before it emits the
turn summary, unless \`UNITARES_AUTO_ONBOARD=off\` or
\`UNITARES_DISABLE_AUTO_ONBOARD=1\` is set. Manual start_session is still
preferred when you need governance MCP calls during the turn.

Do not manufacture a check-in to satisfy this note. Use \`sync_state(...)\`
only when there is meaningful state worth reporting:

    sync_state(response_text=..., complexity=..., confidence=...)

Substrate hooks may record observations automatically. Those observations are
not agent-authored check-ins and do not require you to echo them. Lazy
onboarding is harness-managed attribution for this Claude process; it is not
an agent-authored claim.

Under the identity ontology, fresh process-instances mint fresh
governance-identity. \`force_new=true\` is the default posture; lineage, when
applicable, is declared via \`parent_agent_id\` (see hint below) rather than
resumed via token.

The post-identity hook records your UUID locally so hook-generated summaries
can attach to the chosen identity. Hook-generated summaries are labeled as
substrate interpretation; they should not pressure you to speak in the
agent voice.

After onboarding, read the agent-experience fields in the response:
\`next_action\`, \`state_summary\`, \`risk_summary\`, \`memory_suggestions\`,
and \`recovery_hint\` when present. Treat \`memory_suggestions\` as optional
retrieval prompts and \`recovery_hint\` as the first recovery route when a
tool reports degraded or paused state.

If you need to recover a specific prior identity by UUID, that is an
operator action — run /diagnose for guided recovery rather than guessing
a UUID."
  fi

  if [[ -n "${WORKSPACE_LINEAGE_HINT}" ]]; then
    CONTEXT="${CONTEXT}

${WORKSPACE_LINEAGE_HINT}"
  fi

  # Skip the Fundamentals excerpt in compact mode. The freshness warning
  # (if any) still injects on the *next* fresh-workspace fire when the
  # full block returns, so calibration on stale skill files isn't lost.
  if [[ "${COMPACT_MODE}" != "1" && "${NUDGE_ALREADY_SHOWN}" != "1" && -n "${SKILL_CONTENT}" ]]; then
    CONTEXT="${CONTEXT}

--- Governance Fundamentals (excerpt)${SKILL_SOURCE_SUFFIX} ---
${SKILL_CONTENT}"
  fi
fi

# ---------------------------------------------------------------------------
# Workspace coordination briefing (git-sourced, adoption-independent)
#
# The governance substrate CANNOT answer "who else is live in this workspace"
# — that would require the very check-ins we're trying to elicit. Measured
# 2026-06-15: 16 concurrent worktrees, 2 check-ins in 2h, and core.agents
# status='active' is never reaped (565 stale "active", newest 45m old). So
# sourcing liveness from the substrate returns a confident lie ("0 siblings"),
# which trains agents the tool is junk — worse than silence.
#
# Git worktree state is the check-in-INDEPENDENT ground truth: it knows every
# concurrent branch for free, and UNCOMMITTED edits in a sibling worktree are
# the highest-value collision signal a fresh agent can get before touching a
# shared file. Task-blind at session start, we surface only siblings that
# carry uncommitted work (the actionable hotspots) — precision-or-silence: if
# nothing is dirty, we emit nothing. Fully fail-safe: any git error yields an
# empty briefing and never blocks session start.
# ---------------------------------------------------------------------------
WORKSPACE_BRIEFING=""
if command -v git >/dev/null 2>&1 && git -C "${PWD}" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  SELF_WT="$(git -C "${PWD}" rev-parse --show-toplevel 2>/dev/null || true)"
  BRIEF_LINES=""
  LIVE_COUNT=0
  CUR_WT=""
  while IFS= read -r _line; do
    case "${_line}" in
      "worktree "*)
        CUR_WT="${_line#worktree }"
        ;;
      "branch refs/heads/"*)
        _br="${_line#branch refs/heads/}"
        # Only agent-authored branches count as sibling sessions; skip self,
        # master, detached cron/backup worktrees.
        if [ "${CUR_WT}" != "${SELF_WT}" ]; then
          case "${_br}" in
            claude/*|codex/*)
              LIVE_COUNT=$((LIVE_COUNT + 1))
              _dirty="$(git -C "${CUR_WT}" status --porcelain 2>/dev/null | awk '{print $NF}' | head -3 | paste -sd, - 2>/dev/null)"
              if [ -n "${_dirty}" ]; then
                BRIEF_LINES="${BRIEF_LINES}
  - ${_br} -- uncommitted: ${_dirty}"
              fi
              ;;
          esac
        fi
        ;;
    esac
  done < <(git -C "${PWD}" worktree list --porcelain 2>/dev/null | head -200)
  if [ -n "${BRIEF_LINES}" ]; then
    WORKSPACE_BRIEFING="Workspace coordination (git-sourced -- concurrent worktrees of this repo, NOT governance state):
${LIVE_COUNT} sibling agent branch(es) are checked out in this repo. The following carry UNCOMMITTED edits that will collide if you touch the same files -- coordinate (or branch from their head) before editing those paths:${BRIEF_LINES}
This is local git ground truth (adoption-independent). 'Checked out' is not a proven-running process; treat it as a heads-up, not a lock."
  fi
fi

if [ -n "${WORKSPACE_BRIEFING}" ]; then
  CONTEXT="${CONTEXT}

${WORKSPACE_BRIEFING}"
fi

ESCAPED_CONTEXT="$(escape_for_json "${CONTEXT}")"
cat <<ENDJSON
{
  "additional_context": "${ESCAPED_CONTEXT}",
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${ESCAPED_CONTEXT}"
  }
}
ENDJSON
