#!/usr/bin/env bash
# UNITARES Governance Plugin — PostToolUse hook (onboard|identity|bind_session)
#
# Fires when the agent calls a governance identity-creating/resuming tool.
# Captures the UUID + token + label from the tool response and writes them
# to the slot-scoped session cache.
#
# Agent-initiated identity calls remain authoritative for the slot cache. If
# the agent never calls one, post-stop may lazily onboard with the same cache
# shape so end-of-turn summaries still carry a real client_session_id.
#
# Runs async — must never block or produce output on failure.
set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Diagnostic breadcrumb (off by default). When UNITARES_HOOK_DEBUG=1, append
# one line per silent-exit so operators can see where the chain breaks
# without changing user-visible behavior. Path overridable via
# UNITARES_HOOK_DEBUG_LOG (default ~/.unitares/hook-skips.log).
_breadcrumb() {
  [[ "${UNITARES_HOOK_DEBUG:-0}" != "1" ]] && return 0
  local log="${UNITARES_HOOK_DEBUG_LOG:-${HOME}/.unitares/hook-skips.log}"
  local reason="$1"
  printf '%s | hook=post-identity | reason=%s | pwd=%s\n' \
    "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$reason" "$PWD" \
    >> "${log}" 2>/dev/null || true
}

SESSION_CACHE_HELPER=""
for candidate in \
  "${PLUGIN_ROOT}/scripts/session_cache.py" \
  "${PLUGIN_ROOT}/scripts/client/session_cache.py"
do
  if [[ -f "${candidate}" ]]; then
    SESSION_CACHE_HELPER="${candidate}"
    break
  fi
done
if [[ -z "${SESSION_CACHE_HELPER}" ]]; then
  _breadcrumb no_session_cache_helper
  exit 0
fi

# Claude Code sends the tool event as JSON on stdin.
HOOK_INPUT=""
if [[ ! -t 0 ]]; then
  HOOK_INPUT=$(cat 2>/dev/null) || true
fi
if [[ -z "${HOOK_INPUT}" ]]; then
  _breadcrumb no_stdin
  exit 0
fi

# Extract session_id (slot), tool_name, and the response payload that matters.
# MCP tool responses arrive wrapped as {"content": [{"type":"text","text":"<JSON>"}]}.
# The inner JSON contains uuid, agent_id, client_session_id, continuity_token,
# display_name. We only record for the four identity-creating/resuming tools.
# HOOK_INPUT goes via argv[1] rather than stdin because the heredoc below
# redirects stdin from itself — piping into `python3 - <<'PY'` would be lost.
EXTRACTED=$(python3 - "${HOOK_INPUT}" "${PLUGIN_ROOT}/scripts" <<'PY' 2>/dev/null || true
import json, os, sys

def _skip(reason):
    # Emitted on stdout where bash captures EXTRACTED. The bash side
    # recognizes the __SKIP__ prefix and breadcrumbs the reason when
    # UNITARES_HOOK_DEBUG=1. Plain (non-debug) operation is unchanged
    # because empty/SKIP output both lead to silent exit downstream.
    print(f"__SKIP__:{reason}")
    sys.exit(0)

try:
    data = json.loads(sys.argv[1] if len(sys.argv) > 1 else "{}")
except Exception:
    _skip("hook_input_not_json")

tool_name = (data.get("tool_name") or "").lower()
# Match mcp__<server>__(onboard|start_session|identity|bind_session).
# start_session is the friendly-workflow alias for onboard — without it,
# alias-onboarded sessions never write the slot cache and run dark.
_id_tools = ("onboard", "start_session", "identity", "bind_session")
suffix = tool_name.rsplit("__", 1)[-1] if "__" in tool_name else tool_name
if suffix not in _id_tools:
    _skip(f"tool_name_mismatch:{tool_name or 'empty'}")

# Client-side mirror of server PR #604 (subagent onboard pins write SET-NX):
# subagent tool calls fire this hook under the DRIVER's session_id, so a
# council member's onboard would overwrite the driver's slot cache — every
# later auto-checkin then runs as the subagent, and the next session's
# session-start banner offers the subagent UUID as a lineage candidate
# (observed live 2026-06-12: slot 155d00fa cached council-refire-verify).
# Explicit-only, matching #604: dispatched subagents declare
# spawn_reason="subagent"; inference would mislabel succession onboards.
_tool_input = data.get("tool_input")
if isinstance(_tool_input, dict):
    if str(_tool_input.get("spawn_reason") or "").strip().lower() == "subagent":
        _skip("subagent_onboard_not_cached")

session_id = data.get("session_id") or ""
if not session_id:
    try:
        sys.path.insert(0, sys.argv[2])
        from _slot_from_stdin import slot_from_payload
        session_id = slot_from_payload(sys.argv[1])
    except Exception:
        session_id = ""

resp = data.get("tool_response")
# Claude Code delivers MCP tool responses in two observed shapes:
#   1. dict wrapping `content`: {"content": [{"type": "text", "text": "<json>"}]}
#   2. bare list of content parts: [{"type": "text", "text": "<json>"}]
# Accept either. Empirically (2026-04-19) Claude Code sends shape 2 for MCP
# tools; the previous dict-only check bailed silently on every onboard and
# never wrote the session cache.
parts = None
if isinstance(resp, list):
    parts = resp
elif isinstance(resp, dict) and "content" in resp:
    parts = resp.get("content") or []
if parts and isinstance(parts[0], dict):
    text = parts[0].get("text") or ""
    try:
        resp = json.loads(text)
    except Exception:
        resp = {}

if not isinstance(resp, dict):
    _skip("response_not_dict")
if not resp.get("success", True):
    _skip("response_success_false")

# Only record if we actually got a UUID — otherwise nothing useful to cache.
uuid_val = resp.get("uuid") or (resp.get("bound_identity") or {}).get("uuid")
if not uuid_val:
    _skip("no_uuid_in_response")

# Resume-shaped tools (identity, bind_session) don't carry spawn_reason, so
# the subagent guard above can't see a subagent's identity() call — observed
# live 2026-06-12: a council verifier's late identity() re-captured the
# driver's slot cache minutes after the onboard guard shipped. For these
# tools, only overwrite when the cache is empty (first bind in a fresh
# session) or the response UUID matches the cached one (driver rebind after
# restart — the legitimate recovery path). A deliberate operator-guided
# switch to a different UUID is skipped with a breadcrumb; the stale cache
# self-heals on the next onboard. Minting tools (onboard, start_session)
# stay on the spawn_reason guard: a fresh mint by this session IS the
# session's identity.
if suffix in ("identity", "bind_session"):
    _existing = {}
    try:
        sys.path.insert(0, sys.argv[2])
        from _session_lookup import load_session_for_hook
        _existing = load_session_for_hook(os.getcwd(), sys.argv[1]) or {}
    except Exception:
        _existing = {}
    _cached_uuid = str(_existing.get("uuid") or "")
    if _cached_uuid and _cached_uuid != str(uuid_val):
        _skip("resume_uuid_mismatch_not_cached")

# Identity ontology (, §S11): the
# workspace cache is a lineage anchor, not a resume credential. We stamp
# identifying fields (UUID, agent_id, display_name) so the next process-
# instance's session-start hook can surface the UUID as a parent_agent_id
# candidate — but we no longer write continuity_token. `continuity_token: ""`
# is included explicitly so a --merge write clears any legacy v1 value a
# prior onboard_helper path may have left in the cache. `schema_version: 2`
# marks the post-S11 shape; v1 caches (no schema_version, token present)
# are treated as read-only legacy — readers ignore their token field.
payload = {
    "uuid": uuid_val,
    "agent_id": resp.get("agent_id", "") or (resp.get("bound_identity") or {}).get("agent_id", ""),
    "client_session_id": resp.get("client_session_id", ""),
    "continuity_token": "",
    "display_name": resp.get("display_name", "") or (resp.get("bound_identity") or {}).get("display_name", ""),
    "continuity_token_supported": resp.get("continuity_token_supported", False),
    "session_resolution_source": resp.get("session_resolution_source", ""),
    "slot": session_id,
    "schema_version": 2,
}
# Emit session_id on stdout line 1, JSON payload on line 2 — the shell
# splits them to pass --slot and --json separately.
print(session_id)
print(json.dumps(payload))
PY
)

if [[ -z "${EXTRACTED}" ]]; then
  _breadcrumb python_unknown_skip
  exit 0
fi

# Python heredoc emits __SKIP__:<reason> when it bailed for a known cause.
if [[ "${EXTRACTED}" == __SKIP__:* ]]; then
  _breadcrumb "${EXTRACTED#__SKIP__:}"
  exit 0
fi

SLOT=$(printf '%s' "${EXTRACTED}" | head -n 1)
PAYLOAD=$(printf '%s' "${EXTRACTED}" | tail -n +2)

if [[ -z "${PAYLOAD}" || "${PAYLOAD}" == "{}" ]]; then
  _breadcrumb empty_payload
  exit 0
fi

# Merge into slot-scoped session cache. --merge preserves any fields the
# session-start hook wrote earlier (e.g. server_url, agent_name) while
# overwriting uuid/token/etc. from this response.
SLOT_ARG=()
if [[ -n "${SLOT}" ]]; then
  SLOT_ARG=(--slot "${SLOT}")
fi

python3 "${SESSION_CACHE_HELPER}" \
  set session \
  --workspace "${PWD}" \
  "${SLOT_ARG[@]}" \
  --merge \
  --stamp \
  --json "${PAYLOAD}" >/dev/null 2>&1 || true

exit 0
