# UNITARES Governance Plugin — Default Configuration
UNITARES_SERVER_URL=http://localhost:8767
UNITARES_AGENT_PREFIX=claude

# --- Check-in emission (added 2026-04-17) ---

# Kill switch: set to 'off' to suppress EVERY plugin-emitted check-in
# (session-start, stop, session-end, and the edit-threshold auto-checkin).
UNITARES_CHECKINS=on

# Diagnostic log: every check-in attempt writes one line here with status.
# Tail this file to debug whether check-ins are landing.
UNITARES_CHECKIN_LOG=~/.unitares/checkins.log

# --- Edit-threshold auto-checkin (pre-existing) ---
# Fires a check-in after N edits OR T seconds since last check-in.
UNITARES_AUTO_CHECKIN_ENABLED=1
UNITARES_AUTO_CHECKIN_EDITS=5
UNITARES_AUTO_CHECKIN_SECS=600

# --- BEAM file leases for concurrent agents ---
# PreToolUse Edit/Write/MultiEdit acquires a file:// lease before mutation.
# Missing LEASE_PLANE_BEARER_TOKEN or an unreachable lease plane fails open by
# default; real contention (held_by_other) blocks the edit. Set REQUIRED=1 to
# make missing/unreachable lease infrastructure block edits too.
UNITARES_FILE_LEASES_ENABLED=1
UNITARES_FILE_LEASES_REQUIRED=0
UNITARES_FILE_LEASE_TTL_S=900
UNITARES_FILE_LEASE_TIMEOUT_S=1.0
LEASE_PLANE_BASE_URL=http://127.0.0.1:8788

# --- Operator note on blocking ---
# session-start and session-end invoke checkin.py synchronously with a
# 20s POST timeout. If governance is unreachable (e.g. on a plane), each
# session start/end pays up to ~20s. Set UNITARES_CHECKINS=off to skip
# all emissions entirely.
